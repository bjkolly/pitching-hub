# ===========================================================================
# pitching-hub — Docker Environment Configuration
#
# Copy this file to .env.docker and fill in your values:
#   cp .env.docker.example .env.docker
#
# IMPORTANT: Change JWT_SECRET, ADMIN_USER, and ADMIN_PASS before
# exposing the server publicly.
# ===========================================================================

# ── Server ────────────────────────────────────────────────────────────────
PORT=3001

# ── Authentication ────────────────────────────────────────────────────────
# CHANGE THESE before deploying publicly!
JWT_SECRET=change-me-to-a-random-64-char-string
ADMIN_USER=admin
ADMIN_PASS=changeme

# ── Anthropic API (required for CrewAI pipeline + school resolution) ─────
# Get your key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ── Trackman API (optional — leave blank for mock/demo mode) ─────────────
TRACKMAN_API_KEY=
TRACKMAN_TEAM_ID=
TRACKMAN_BASE_URL=https://staging-api.trackmanbaseball.com/v1
