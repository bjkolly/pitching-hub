# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001

# ── Trackman API ──────────────────────────────────────────────────────────────
# Obtain these from your Trackman developer portal / team administrator.
# Leave blank (or omit) to run in mock mode — all endpoints still work.

# Bearer token for API authentication
TRACKMAN_API_KEY=

# Your organisation or team identifier
TRACKMAN_TEAM_ID=

# REST base URL — defaults to staging if unset.
# Staging:    https://staging-api.trackmanbaseball.com/v1
# Production: https://api.trackmanbaseball.com/v1
TRACKMAN_BASE_URL=https://staging-api.trackmanbaseball.com/v1
